@model phpMVC.Models.PostJobViewModel
@{
    ViewData["Title"] = "Post a Service | WorkConnect";
}

@section Styles {
    <link rel="stylesheet" href="~/css/postjob.css" />
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1>Post a Service</h1>
        <p>Offer your skills and services to clients in need</p>
    </div>
</section>

<!-- Service Posting Form -->
<section class="post-job">
    <div class="container">
        <div class="form-container">
            <div class="form-header">
                <h2><i class="fas fa-briefcase"></i> Service Details</h2>
                <p>Fill in the details about the service you're offering</p>
            </div>

            <!-- SUCCESS MESSAGE -->
            @if (TempData["ShowSuccessMessage"] != null && (bool)TempData["ShowSuccessMessage"])
            {
                <div class="success-message-popup" id="successMessage">
                    <div class="success-icon">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <h3>@TempData["SuccessMessage"]</h3>
                    <p>Your service has been listed and is now visible to clients.</p>
                    <div class="success-actions">
                        <a asp-controller="Services" asp-action="Index" class="btn btn-primary">
                            <i class="fas fa-eye"></i> View All Services
                        </a>
                        <button type="button" class="btn btn-secondary" onclick="closeSuccessMessage()">
                            <i class="fas fa-plus"></i> Post Another
                        </button>
                    </div>
                </div>
            }

            <!-- ERROR MESSAGE -->
            <!-- ERROR MESSAGES - Show both TempData and ModelState errors -->
            @if (!ViewData.ModelState.IsValid || TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger" style="margin-bottom: 20px; padding: 15px; background: #f8d7da; border: 1px solid #f5c6cb; border-radius: 5px; color: #721c24;">
                    <i class="fas fa-exclamation-triangle"></i>
                    <strong>Please correct the following errors:</strong>

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div style="margin-top: 10px;">@TempData["ErrorMessage"]</div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <ul style="margin-top: 10px; margin-bottom: 0; padding-left: 20px;">
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                foreach (var error in modelState.Errors)
                                {
                                    <li style="margin-bottom: 5px;">@error.ErrorMessage</li>
                                }
                            }
                        </ul>
                    }
                </div>
            }

            <form asp-action="Create" method="post" id="jobForm" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- Service Image Upload -->
                <div class="image-upload-section">
                    <h3><i class="fas fa-image"></i> Service Image</h3>
                    <p>Upload an image that represents your service (optional but recommended)</p>

                    <div class="image-preview-container">
                        <!-- Image Preview -->
                        <div id="imagePreviewContainer" style="display: none;">
                            <img id="imagePreview" class="image-preview"
                                 src="#" alt="Service Image Preview" />
                            <div id="fileName" class="file-info"></div>
                        </div>

                        <!-- Placeholder -->
                        <div id="placeholder">
                            <div class="placeholder-icon">
                                <i class="fas fa-cloud-upload-alt"></i>
                            </div>
                            <p>Click to choose an image</p>
                        </div>

                        <!-- Upload Actions -->
                        <div class="upload-actions">
                            <button type="button" class="btn btn-outline" onclick="document.getElementById('serviceImage').click()">
                                <i class="fas fa-upload"></i> Choose Image
                            </button>
                            <button type="button" class="btn btn-secondary" onclick="removeImage()">
                                <i class="fas fa-trash"></i> Remove
                            </button>
                        </div>

                        <!-- File Input -->
                        <input type="file" asp-for="ServiceImage"
                               id="serviceImage"
                               style="display: none;"
                               accept="image/*"
                               onchange="previewImage(this)" />

                        <!-- Help Text -->
                        <div class="form-text">
                            <small>Max file size: 5MB. Supported formats: JPG, PNG, GIF, WEBP</small>
                        </div>
                    </div>
                </div>

                <!-- Service Title -->
                <div class="form-row">
                    <div class="form-group full-width">
                        <label asp-for="ServiceTitle"></label>
                        <input asp-for="ServiceTitle" class="form-control"
                               placeholder="e.g., Professional Plumbing Services, House Cleaning"
                               maxlength="200" />
                    </div>
                </div>

                <!-- Service Type -->
                <div class="form-row">
                    <div class="form-group full-width">
                        <label asp-for="ServiceType"></label>
                        <input asp-for="ServiceType" class="form-control"
                               placeholder="e.g., Plumbing, Cleaning, Electrical, Tutoring"
                               maxlength="50" />
                    </div>
                </div>

                <!-- Price Section -->
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Price"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Price" class="form-control"
                                   placeholder="e.g., 50"
                                   type="number"
                                   min="0.01"
                                   step="0.01" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="PriceType"></label>
                        <select asp-for="PriceType" class="form-control">
                            <option value="hourly">Per Hour</option>
                            <option value="fixed">Fixed Price</option>
                            <option value="daily">Per Day</option>
                            <option value="project">Per Project</option>
                        </select>
                    </div>
                </div>

                <!-- Location & Duration -->
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Location"></label>
                        <input asp-for="Location" class="form-control"
                               placeholder="e.g., Cape Town"
                               maxlength="100" />
                    </div>

                    <div class="form-group">
                        <label asp-for="Duration"></label>
                        <input asp-for="Duration" class="form-control"
                               placeholder="e.g., 2 hours, Half Day"
                               maxlength="50" />
                    </div>
                </div>

                <!-- Service Description -->
                <div class="form-group full-width">
                    <label asp-for="JobDescription"></label>
                    <textarea asp-for="JobDescription" class="form-control"
                              rows="6"
                              placeholder="Describe your service in detail..."
                              maxlength="2000"></textarea>
                    <div class="char-count">
                        <span id="charCount">0</span> / 2000 characters
                    </div>
                </div>

                <!-- Availability -->
                <div class="form-group full-width">
                    <label asp-for="Availability"></label>
                    <input asp-for="Availability" class="form-control"
                           placeholder="e.g., Monday-Friday 9am-5pm, Weekends Available"
                           maxlength="100" />
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Post Service</button>
                    <a asp-controller="Services" asp-action="Index" class="btn btn-link">Cancel</a>
                </div>
            </form>
        </div>

        <!-- Sidebar Tips -->
        <div class="sidebar-tips">
            <div class="tips-card">
                <h3><i class="fas fa-lightbulb"></i> Tips for a Great Service Post</h3>
                <ul>
                    <li><strong>Add a clear image</strong> of your work or service</li>
                    <li><strong>Be specific</strong> about what you offer</li>
                    <li><strong>Set competitive pricing</strong> for your area</li>
                    <li><strong>Clearly state your availability</strong></li>
                    <li><strong>Include relevant experience</strong> and skills</li>
                    <li><strong>Respond quickly</strong> to client inquiries</li>
                </ul>
            </div>

            <div class="pricing-card">
                <h3><i class="fas fa-tag"></i> Benefits</h3>
                <div class="price-item">
                    <span class="price-label">Free Listing</span>
                    <span class="price-value">Always Free</span>
                </div>
                <div class="price-item">
                    <span class="price-label">Direct Client Contact</span>
                    <span class="price-value">✓ Included</span>
                </div>
                <div class="price-item">
                    <span class="price-label">Client Reviews</span>
                    <span class="price-value">✓ Build Reputation</span>
                </div>
                <div class="price-item">
                    <span class="price-label">Image Upload</span>
                    <span class="price-value">✓ Attract Clients</span>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Image preview functionality
        function previewImage(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                const reader = new FileReader();

                // Validate file size (5MB)
                if (file.size > 5 * 1024 * 1024) {
                    alert('File size exceeds 5MB limit. Please choose a smaller file.');
                    input.value = '';
                    return;
                }

                // Validate file type
                const validTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
                if (!validTypes.includes(file.type)) {
                    alert('Please select a valid image file (JPG, PNG, GIF, WEBP).');
                    input.value = '';
                    return;
                }

                reader.onload = function (e) {
                    const preview = document.getElementById('imagePreview');
                    const container = document.getElementById('imagePreviewContainer');
                    const placeholder = document.getElementById('placeholder');
                    const fileName = document.getElementById('fileName');

                    preview.src = e.target.result;
                    container.style.display = 'block';
                    placeholder.style.display = 'none';
                    fileName.textContent = `Selected: ${file.name} (${(file.size / 1024).toFixed(2)} KB)`;
                };

                reader.readAsDataURL(file);
            }
        }

        function removeImage() {
            const input = document.getElementById('serviceImage');
            const container = document.getElementById('imagePreviewContainer');
            const placeholder = document.getElementById('placeholder');
            const preview = document.getElementById('imagePreview');
            const fileName = document.getElementById('fileName');

            input.value = '';
            container.style.display = 'none';
            placeholder.style.display = 'block';
            preview.src = '#';
            fileName.textContent = '';
        }

        // Character count for description
        function updateCharCount() {
            const textarea = document.getElementById('JobDescription');
            const charCount = document.getElementById('charCount');
            if (textarea && charCount) {
                charCount.textContent = textarea.value.length;
            }
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function () {
            const txtDescription = document.getElementById('JobDescription');
            if (txtDescription) {
                txtDescription.addEventListener('input', updateCharCount);
                updateCharCount(); // Initial count
            }

            // Form submit handling
            const form = document.getElementById('jobForm');
            if (form) {
                form.addEventListener('submit', function () {
                    const submitBtn = form.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Posting...';
                        submitBtn.disabled = true;
                    }
                });
            }
        });

        function closeSuccessMessage() {
            document.getElementById('successMessage').style.display = 'none';
            // Clear the form
            document.getElementById('jobForm').reset();
            // Reset image preview
            removeImage();
            // Reset character count
            updateCharCount();
        }

        // Auto-hide success message after 10 seconds
        setTimeout(function () {
            const msg = document.getElementById('successMessage');
            if (msg) {
                msg.style.display = 'none';
            }
        }, 10000);
    </script>
}
