@model phpMVC.Models.ServiceSearchViewModel
@{
    ViewData["Title"] = "Find Services | WorkConnect";
}

@section Styles {
    <link rel="stylesheet" href="~/css/services.css" />
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1>Find Service Professionals</h1>
        <p>Browse skilled workers and service providers in your area</p>
    </div>
</section>

<!-- Search Filters -->
<section class="search-filters">
    <div class="container">
        <div class="filter-container">
            <form asp-action="Index" method="get" class="search-form">
                <div class="search-row">
                    <div class="search-group">
                        <label for="ServiceType"><i class="fas fa-search"></i> Service Type</label>
                        <input asp-for="ServiceType" class="form-control" placeholder="e.g., Plumber, Electrician, Tutor" />
                    </div>
                    <div class="search-group">
                        <label for="Location"><i class="fas fa-map-marker-alt"></i> Location</label>
                        <input asp-for="Location" class="form-control" placeholder="City, State, or ZIP" />
                    </div>
                    <div class="search-group">
                        <label for="Duration"><i class="fas fa-clock"></i> Duration</label>
                        <select asp-for="Duration" class="form-control">
                            <option value="">Any Duration</option>
                            <option value="1-3 hours">1-3 hours</option>
                            <option value="Half Day">Half Day (4 hours)</option>
                            <option value="Full Day">Full Day (8 hours)</option>
                            <option value="Multiple Days">Multiple Days</option>
                            <option value="Ongoing">Ongoing</option>
                        </select>
                    </div>
                    <div class="search-group">
                        <label for="PriceRange"><i class="fas fa-dollar-sign"></i> Price Range</label>
                        <select asp-for="PriceRange" class="form-control">
                            <option value="">Any Price</option>
                            <option value="1">Under $50</option>
                            <option value="2">$50 - $100</option>
                            <option value="3">$100 - $200</option>
                            <option value="4">$200 - $500</option>
                            <option value="5">$500+</option>
                        </select>
                    </div>
                    <button type="submit" class="btn search-btn">Search Services</button>
                </div>
            </form>

            <div class="quick-filters">
                <span>Popular Categories:</span>
                <a asp-action="ApplyCategoryFilter" asp-route-category="home" class="filter-tag">Home Services</a>
                <a asp-action="ApplyCategoryFilter" asp-route-category="tech" class="filter-tag">Tech Services</a>
                <a asp-action="ApplyCategoryFilter" asp-route-category="education" class="filter-tag">Tutoring</a>
                <a asp-action="ApplyCategoryFilter" asp-route-category="beauty" class="filter-tag">Beauty & Wellness</a>
                <a asp-action="ApplyCategoryFilter" asp-route-category="delivery" class="filter-tag">Delivery</a>
                <a asp-action="ApplyCategoryFilter" asp-route-category="automotive" class="filter-tag">Automotive</a>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section class="services">
    <div class="container">
        <div class="services-header">
            <h2>Available Services <span id="resultCount">(@Model.TotalServices services found)</span></h2>
            <div class="sort-options">
                <select asp-for="SortBy" asp-items="ViewBag.SortOptions" class="form-control" onchange="this.form.submit()">
                    <option value="rating">Highest Rated</option>
                    <option value="price_low">Price: Low to High</option>
                    <option value="price_high">Price: High to Low</option>
                    <option value="newest">Newest First</option>
                </select>
            </div>
        </div>

        <div class="row">
            @if (Model.Services != null && Model.Services.Any())
            {
                foreach (var service in Model.Services)
                {
                    <div class="col-4">
                        <div class="service-card">
                            @if (!string.IsNullOrEmpty(service.BadgeText))
                            {
                                <span class="service-badge @service.BadgeClass">@service.BadgeText</span>
                            }
                            <img src="@service.ImageUrl" alt="@service.Name" />
                            <h3>Provider name</h3>
                            <h2>@service.ProviderName</h2>
                            <div class="service-provider">
                                <img src="@service.ProviderImage" alt="Provider" class="provider-avatar" />
                               
                            </div>
                            <h3>@service.Name</h3>
                            <p class="service-description">@service.Description</p>
                          
                            <div class="service-details">
                                <div class="detail">
                                    <i class="fas fa-map-marker-alt"></i>
                                    <span>@service.Location</span>
                                </div>
                                <div class="detail">
                                    <i class="fas fa-clock"></i>
                                    <span>@service.Duration</span>
                                </div>
                                <div class="detail">
                                    <i class="fas fa-calendar"></i>
                                    <span>@service.Availability</span>
                                </div>
                            </div>
                            <div class="rating">
                                @for (int i = 0; i < 5; i++)
                                {
                                    if (i < Math.Floor(service.Rating))
                                    {
                                        <i class="fas fa-star"></i>
                                    }
                                    else if (i < service.Rating)
                                    {
                                        <i class="fas fa-star-half-alt"></i>
                                    }
                                    else
                                    {
                                        <i class="far fa-star"></i>
                                    }
                                }
                                <span class="rating-count">(@service.ReviewCount reviews)</span>
                            </div>
                        
                            <div class="service-footer">
                                @{
                                    string userType = Context.Session.GetString("UserType");
                                    string userId = Context.Session.GetString("UserId");
                                    bool isCustomer = userType == "customer";
                                    bool isLoggedIn = !string.IsNullOrEmpty(userId);
                                }

                                <p class="price">From: <strong>$@service.Price.ToString("0.00")</strong></p>
                                <div class="service-card-actions">
                                    @if (isCustomer)
                                    {
                                        <a asp-controller="Bookings"
                                           asp-action="Book"
                                           asp-route-serviceId="@service.Id"
                                           class="btn btn-small book-btn">
                                            <i class="fas fa-calendar-check"></i> Book
                                        </a>

                                        <a asp-controller="Chat"
                                           asp-action="Open"
                                           asp-route-providerId="@service.ProviderId"
                                           class="btn btn-small book-btn"
                                           title="Message @service.ProviderName">
                                            <i class="fas fa-comment-dots"></i> Message
                                        </a>
                                    }
                                    else if (!isLoggedIn)
                                    {
                                        <a asp-controller="Account" asp-action="Login" class="btn btn-small book-btn">
                                            <i class="fas fa-sign-in-alt"></i> Login to Book
                                        </a>
                                    }
                                </div>
                            </div>
                            
                                </div>
                            </div>



                }
            }
            else
            {
                <div class="empty-message">
                    No services found matching your criteria.
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (Model.TotalPages > 1)
        {
            <div class="pagination">
                @if (Model.Page > 1)
                {
                    <a asp-action="Index"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-serviceType="@Model.ServiceType"
                       asp-route-location="@Model.Location"
                       asp-route-duration="@Model.Duration"
                       asp-route-priceRange="@Model.PriceRange"
                       asp-route-sortBy="@Model.SortBy"
                       class="page-btn">
                        <i class="fas fa-chevron-left"></i>
                    </a>
                }

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <a asp-action="Index"
                       asp-route-page="@i"
                       asp-route-serviceType="@Model.ServiceType"
                       asp-route-location="@Model.Location"
                       asp-route-duration="@Model.Duration"
                       asp-route-priceRange="@Model.PriceRange"
                       asp-route-sortBy="@Model.SortBy"
                       class="page-btn @(i == Model.Page ? "active" : "")">
                        @i
                    </a>
                }

                @if (Model.Page < Model.TotalPages)
                {
                    <a asp-action="Index"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-serviceType="@Model.ServiceType"
                       asp-route-location="@Model.Location"
                       asp-route-duration="@Model.Duration"
                       asp-route-priceRange="@Model.PriceRange"
                       asp-route-sortBy="@Model.SortBy"
                       class="page-btn">
                        <i class="fas fa-chevron-right"></i>
                    </a>
                }
            </div>
        }
    </div>
</section>
