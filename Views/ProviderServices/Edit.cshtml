@model phpMVC.Models.ProviderServiceViewModel
@{
    ViewData["Title"] = "Edit Service | WorkConnect";
}

@section Styles {
    <link rel="stylesheet" href="~/css/provider-services.css" />
}

<!-- Page Header -->
<section class="page-header">
    <div class="container">
        <h1>Edit Service</h1>
        <p>Update your service information</p>
    </div>
</section>

<!-- Edit Form Section -->
<section class="edit-section">
    <div class="container">
        <div class="form-container">
            <!-- Error Summary -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <i class="fas fa-exclamation-triangle"></i>
                    <strong>Please correct the following errors:</strong>
                    <ul style="margin-top: 10px; margin-bottom: 0;">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <!-- Service Image -->
                <div class="image-upload-section">
                    <h4><i class="fas fa-image"></i> Service Image</h4>

                    <div class="image-preview-container">
                        <!-- Current Image -->
                        @if (!string.IsNullOrEmpty(Model.ServiceImagePath))
                        {
                            <div class="current-image">
                                @{
                                    // Fix the image path - ensure it has a leading slash
                                    string imageUrl = Model.ServiceImagePath;
                                    if (!imageUrl.StartsWith("/") && !imageUrl.StartsWith("http"))
                                    {
                                        imageUrl = "/" + imageUrl;
                                    }
                                }
                                <img src="@imageUrl" alt="Current" class="service-image-preview"
                                     onerror="this.onerror=null; this.src='/images/default-service.jpg'; console.log('Failed to load: ' + this.src);" />
                                <p class="current-label">Current Image</p>
                                <div class="image-path-info" style="margin-top: 10px; padding: 8px; background: #f5f5f5; border-radius: 4px;">
                                    <p style="margin: 0; font-size: 0.85rem; color: #666;">
                                        <i class="fas fa-image"></i>
                                        @* <strong>Path in DB:</strong> @Model.ServiceImagePath<br />
                                        <strong>Fixed URL:</strong> @imageUrl *@
                                    </p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="no-image">
                                <i class="fas fa-image" style="font-size: 3rem; color: #ccc;"></i>
                                <p>No image uploaded</p>
                            </div>
                        }

                        <!-- New Image Preview -->
                        <div id="newImagePreviewContainer" style="display: none;">
                            <h5>New Image:</h5>
                            <img id="newImagePreview" class="service-image-preview" src="#" alt="Preview" />
                            <div id="fileName" class="file-info"></div>
                        </div>

                        <!-- Upload Controls -->
                        <div class="upload-controls">
                            <button type="button" class="btn btn-outline" onclick="document.getElementById('serviceImage').click()">
                                <i class="fas fa-upload"></i> Choose New Image
                            </button>
                            <button type="button" class="btn btn-secondary" onclick="removeNewImage()">
                                <i class="fas fa-times"></i> Clear Selection
                            </button>
                        </div>

                        <input type="file" asp-for="ServiceImage"
                               id="serviceImage"
                               style="display: none;"
                               accept="image/*"
                               onchange="previewNewImage(this)" />

                        <div class="form-text">
                            <small>Max file size: 5MB. Leave empty to keep current image.</small>
                        </div>
                        <span asp-validation-for="ServiceImage" class="text-danger"></span>
                    </div>
                </div>

                <!-- Service Title -->
                <div class="form-group">
                    <label asp-for="ServiceTitle">Service Title</label>
                    <input asp-for="ServiceTitle" class="form-control" />
                    <span asp-validation-for="ServiceTitle" class="text-danger"></span>
                </div>

                <!-- Description -->
                <div class="form-group">
                    <label asp-for="JobDescription">Description</label>
                    <textarea asp-for="JobDescription" class="form-control" rows="6"></textarea>
                    <span asp-validation-for="JobDescription" class="text-danger"></span>
                </div>

                <!-- Location & Duration -->
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Location">Location</label>
                        <input asp-for="Location" class="form-control" />
                        <span asp-validation-for="Location" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Duration">Duration</label>
                        <input asp-for="Duration" class="form-control" />
                        <span asp-validation-for="Duration" class="text-danger"></span>
                    </div>
                </div>

                <!-- Availability -->
                <div class="form-group">
                    <label asp-for="Availability">Availability</label>
                    <input asp-for="Availability" class="form-control" />
                    <span asp-validation-for="Availability" class="text-danger"></span>
                </div>

                <!-- Price -->
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Price">Price</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Price" class="form-control" type="number" step="0.01" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="PriceType">Price Type</label>
                        <select asp-for="PriceType" class="form-control">
                            <option value="hourly">Per Hour</option>
                            <option value="fixed">Fixed Price</option>
                            <option value="daily">Per Day</option>
                            <option value="project">Per Project</option>
                        </select>
                    </div>
                </div>

                <!-- Status -->
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" asp-for="IsActive" />
                        <span>Service is active and visible to customers</span>
                    </label>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Save Changes
                    </button>
                    <a asp-action="Index" class="btn btn-link">
                        <i class="fas fa-arrow-left"></i> Back to Services
                    </a>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function previewNewImage(input) {
            if (input.files && input.files[0]) {
                const file = input.files[0];
                const reader = new FileReader();

                // Validate file size
                if (file.size > 5 * 1024 * 1024) {
                    alert('File size exceeds 5MB limit.');
                    input.value = '';
                    return;
                }

                // Validate file type
                const validTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
                if (!validTypes.includes(file.type)) {
                    alert('Please select a valid image file (JPG, PNG, GIF, WEBP).');
                    input.value = '';
                    return;
                }

                reader.onload = function (e) {
                    document.getElementById('newImagePreview').src = e.target.result;
                    document.getElementById('newImagePreviewContainer').style.display = 'block';
                    document.getElementById('fileName').textContent = `Selected: ${file.name} (${(file.size / 1024).toFixed(2)} KB)`;
                };

                reader.readAsDataURL(file);
            }
        }

        function removeNewImage() {
            document.getElementById('serviceImage').value = '';
            document.getElementById('newImagePreviewContainer').style.display = 'none';
            document.getElementById('fileName').textContent = '';
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}
